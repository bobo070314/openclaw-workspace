# ============================================
# 猫抓 V5.x 环境配置
# 创建时间: 2026-06-25
# ============================================

# ── 模型 API Keys ──
# DeepSeek（性价比最高，用于 Worker Brain 和日常任务）
# 获取地址: https://platform.deepseek.com/  → API Keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Claude（档次最高，用于 Commander Brain 和复杂推理）
# 获取地址: https://console.anthropic.com/  → API Keys
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI（兼容性最好）
# OPENAI_API_KEY=sk-...

# ── 记忆库配置 ──
MEMORY_VECTOR_DB_PATH=data/memory_vectors
MEMORY_INDEX_PATH=data/memory_index
MEMORY_STORE_PATH=states/memory_store.json

# ── 安全与沙箱 ──
SANDBOX_WORKSPACE_ROOT=D:/bobo/openclaw-foreign/workspace
SAFETY_CHECK_ENABLED=true
YOLO_CLASSIFIER_ENABLED=true

# ── 成本追踪 ──
COST_TRACKER_ENABLED=true
DAILY_BUDGET_USD=5.0
MONTHLY_BUDGET_USD=50.0

# ── Kairos 调度器 ──
KAIROS_ENABLED=true
KAIROS_STATE_FILE=states/kairos_state.json

# ── 合规防火墙 ──
COMPLIANCE_FIREWALL_ENABLED=true
COMPLIANCE_LOG_DIR=logs/compliance
